{
  "name": "15bn-command-app",
  "version": "1.0.0",
  "description": "Vehicle Maintenance Command Dashboard",
  "main": "main.js",
  "author": "15th Bn Command",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w sqlite3",
    "dist": "npm run rebuild && electron-builder"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^33.2.1",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.15bn.command",
    "productName": "15th Bn Command",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server/**/*",
      "ui/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "ui/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
