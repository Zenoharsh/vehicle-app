{
  "name": "15bn-command-app",
  "version": "2.0.0",
  "description": "Vehicle Maintenance Command Dashboard",
  "main": "main.js",
  "author": "15th Bn Command",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w sqlite3",
    "dist": "electron-builder"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.15bn.command",
    "productName": "15th Bn Command",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server/**/*",
      "ui/**/*",
      "node_modules/**/*",
      "node_modules/sqlite3/build/Release/node_sqlite3.node",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": "nsis",
      "icon": "ui/assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
